PORT=3000
REMINDER_MINUTES=15
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=web_time
MYSQL_SSL=false
MYSQL_SSL_REJECT_UNAUTHORIZED=true
# MYSQL_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=replace_with_npm_run_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_npm_run_vapid_private_key
